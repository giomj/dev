# n2yo.com API key — per-device, never shared, never committed.
# Register at https://www.n2yo.com/login/ and generate a key.
# Session 3 ruling (Engineer): keys travel per-device via .env; the repo carries only this example.

N2YO_API_KEY=YOUR_KEY_HERE

# Rate limits (informational — enforced by n2yo server-side):
#   TLE endpoint: 1000 requests / hour
#   Passes / Above endpoints: 100 requests / hour
#
# Session 4 ruling (Skeptic reinforcement): the CI attribution check enforces
# a rate-of-change gate on sources/n2yo/cache/ — bulk redistribution is blocked
# at commit time, not merely at API time.
